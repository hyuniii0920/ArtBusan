<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#05070D">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_arrow_back"
            android:tint="#E8F0FE"
            android:contentDescription="뒤로가기"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_language"
            android:textColor="#60A5FA"
            android:textSize="9sp"
            android:fontFamily="monospace"
            android:letterSpacing="0.15"
            android:layout_marginBottom="4dp" />

        <!-- 현재 선택된 언어 표시 -->
        <TextView
            android:id="@+id/tvSelectedLanguage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="한국어"
            android:textColor="#E8F0FE"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="20dp" />

        <RadioGroup
            android:id="@+id/radioGroupLanguage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <RadioButton
                android:id="@+id/radioKorean"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="#0E1320"
                android:paddingStart="16dp"
                android:text="한국어"
                android:textColor="#E8F0FE"
                android:textSize="15sp"
                android:checked="true"
                android:buttonTint="#2563EB"
                android:layout_marginBottom="8dp" />

            <RadioButton
                android:id="@+id/radioEnglish"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="#0E1320"
                android:paddingStart="16dp"
                android:text="English"
                android:textColor="#E8F0FE"
                android:textSize="15sp"
                android:buttonTint="#2563EB"
                android:layout_marginBottom="8dp" />

            <RadioButton
                android:id="@+id/radioJapanese"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="#0E1320"
                android:paddingStart="16dp"
                android:text="日本語"
                android:textColor="#E8F0FE"
                android:textSize="15sp"
                android:buttonTint="#2563EB"
                android:layout_marginBottom="8dp" />

            <RadioButton
                android:id="@+id/radioChinese"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="#0E1320"
                android:paddingStart="16dp"
                android:text="中文"
                android:textColor="#E8F0FE"
                android:textSize="15sp"
                android:buttonTint="#2563EB" />

        </RadioGroup>

        <!-- 더미 설명 텍스트 (선택 언어로 변경) -->
        <TextView
            android:id="@+id/tvLangNote"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/language_note"
            android:textColor="#60A5FA"
            android:textSize="12sp"
            android:layout_marginTop="16dp" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>

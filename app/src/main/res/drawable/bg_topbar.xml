<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 다크 배경 -->
    <item>
        <shape>
            <solid android:color="#0E1320" />
        </shape>
    </item>
    <!-- 하단 네온 라인 -->
    <item
        android:top="-2dp"
        android:left="-2dp"
        android:right="-2dp">
        <shape>
            <solid android:color="#00000000" />
            <stroke android:width="1.5dp" android:color="#2563EB" />
        </shape>
    </item>
</layer-list>

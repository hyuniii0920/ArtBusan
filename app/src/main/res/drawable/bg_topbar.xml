<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 라이트 배경 -->
    <item>
        <shape>
            <solid android:color="@color/bg_surface" />
        </shape>
    </item>
    <!-- 하단 포인트 컬러 라인 -->
    <item
        android:top="-2dp"
        android:left="-2dp"
        android:right="-2dp">
        <shape>
            <solid android:color="#00000000" />
            <stroke android:width="1.5dp" android:color="@color/primary_teal" />
        </shape>
    </item>
</layer-list>

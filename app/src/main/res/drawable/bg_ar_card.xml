<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 라이트 그라디언트 배경 -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="135"
                android:startColor="#FAF9F6"
                android:endColor="#F4F4F4"
                android:type="linear" />
        </shape>
    </item>
    <!-- 좌측 상단 포인트 컬러 글로우 -->
    <item
        android:right="-40dp"
        android:bottom="-40dp">
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:gradientRadius="120dp"
                android:startColor="#408CD5CB"
                android:endColor="#008CD5CB"
                android:centerX="0.0"
                android:centerY="0.0" />
        </shape>
    </item>
    <!-- 상단 포인트 컬러 라인 -->
    <item
        android:bottom="-2dp"
        android:left="-2dp"
        android:right="-2dp">
        <shape android:shape="rectangle">
            <solid android:color="#00000000" />
            <stroke android:width="1dp" android:color="#338CD5CB" />
        </shape>
    </item>
</layer-list>

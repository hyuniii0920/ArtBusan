<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 라이트 그라디언트 배경 -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="135"
                android:startColor="#FAF9F6"
                android:endColor="#F4F4F4"
                android:type="linear" />
        </shape>
    </item>
    <!-- 하단 포인트 컬러 라인 -->
    <item
        android:top="-2dp"
        android:left="-2dp"
        android:right="-2dp">
        <shape android:shape="rectangle">
            <solid android:color="#00000000" />
            <stroke android:width="1dp" android:color="#8CD5CB" />
        </shape>
    </item>
</layer-list>
